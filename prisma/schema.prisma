// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../frontend/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TradeInStatus {
  PENDING
  REVIEWED
  REJECTED
  ACCEPTED
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id            String         @id @default(cuid())
  sku           String         @unique
  name          String
  brand         String         @default("Apple")
  model         String
  color         String
  storage       Int
  batteryHealth Int?
  condition     String
  priceArs      Decimal        @db.Decimal(12, 2)
  stock         Int            @default(0)
  featured      Boolean        @default(false)
  description   String?
  images        ProductImage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model TradeInRequest {
  id            String        @id @default(cuid())
  fullName      String
  phone         String
  email         String?
  city          String?
  brand         String
  model         String
  storage       String?
  condition     String
  batteryHealth Int?
  details       String?
  desiredModel  String?
  status        TradeInStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

/// Fila única (id = 1): JSON con la configuración del sitio / panel.
model SiteSettings {
  id        Int      @id
  data      Json
  updatedAt DateTime @updatedAt
}
